{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mybabyshire.com"
        }
      ],
      "destination": "https://www.mybabyshire.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/admin-google-start", "destination": "/api/admin/login?authMode=admin-google" },
    { "source": "/api/admin-google-callback", "destination": "/api/admin/login?authMode=admin-google" },
    { "source": "/api/account/google/start", "destination": "/api/admin/login" },
    { "source": "/api/account/google/callback", "destination": "/api/admin/login" },
    { "source": "/api/account/me", "destination": "/api/admin/login?accountRoute=me" },
    { "source": "/api/account/orders", "destination": "/api/admin/login?accountRoute=orders" },
    { "source": "/admin", "destination": "/" },
    { "source": "/admin/(.*)", "destination": "/" },
    { "source": "/account", "destination": "/" },
    { "source": "/account/(.*)", "destination": "/" },
    { "source": "/products/(.*)", "destination": "/" },
    { "source": "/checkout", "destination": "/" },
    { "source": "/track-order", "destination": "/" },
    { "source": "/payment-success", "destination": "/" },
    { "source": "/payment-cancel", "destination": "/" },
    { "source": "/paypal-success", "destination": "/" }
  ]
}
